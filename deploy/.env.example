# AI调度中心 - 生产环境环境变量配置
# 复制此文件为 .env 并修改实际值

# ============================================
# 数据库配置
# ============================================

# MySQL root密码（必须修改！）
MYSQL_ROOT_PASSWORD=YourStrongRootPassword123!

# MySQL应用用户
MYSQL_USER=aikey

# MySQL应用密码（必须修改！）
MYSQL_PASSWORD=YourStrongUserPassword123!

# ============================================
# 跨域配置
# ============================================

# 允许的跨域来源
# 格式: 协议+域名，多个用逗号分隔
# 示例: https://your-app.netlify.app,https://your-app2.netlify.app
# 生产环境不建议使用 *，应该指定具体域名
CORS_ALLOWED_ORIGINS=https://your-app.netlify.app

# ============================================
# JWT配置（可选，使用默认值可省略）
# ============================================

# JWT密钥（建议修改，至少256位）
# JWT_SECRET=your-jwt-secret-key-here

# Token过期时间（毫秒，默认2小时）
# JWT_EXPIRATION=7200000

# ============================================
# AES加密配置（可选，使用默认值可省略）
# ============================================

# AES密钥（32字符，建议修改）
# AES_SECRET_KEY=your-aes-secret-key-32chars!
